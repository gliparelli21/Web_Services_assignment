pipeline {
    agent any

    options {
        timestamps()
        timeout(time: 10, unit: 'MINUTES')
    }

    triggers {
        cron('H/30 * * * *')
    }

    environment {
        MONITORING_CREDENTIALS = credentials('api-monitoring-credentials')
        WORK_DIR = 'github-src'
        API_CONTAINER = 'ws-assignment-api-container'
        PIPELINE_NETWORK = 'ws-assignment-net'
        API_PORT = '8000'
        GIT_REPO_URL = 'https://github.com/gliparelli21/Web_Services_assignment.git'
        BRANCH = 'main'
    }

    stages {
        stage('Clone Repository') {
            steps {
                bat '''
                    if exist "%WORK_DIR%" rmdir /s /q "%WORK_DIR%"
                    git clone --depth 1 --branch "%BRANCH%" "%GIT_REPO_URL%" "%WORK_DIR%"
                '''
            }
        }

        stage('Check API Availability') {
            steps {
                dir("${WORK_DIR}") {
                    bat '''
                        setlocal enabledelayedexpansion
                        
                        docker inspect -f "{{.State.Running}}" %API_CONTAINER% >nul 2>&1
                        if !errorlevel! equ 0 (
                            echo [PASS] API container running
                            exit /b 0
                        )
                        
                        echo [FAIL] API container not found - run main pipeline first
                        exit /b 1
                    '''
                }
            }
        }

        stage('Run Postman Monitor') {
            steps {
                dir("${WORK_DIR}") {
                    powershell '''
                        if (!(Test-Path "monitoring-reports")) {
                            New-Item -ItemType Directory -Path "monitoring-reports" -Force | Out-Null
                        }
                        
                        $CurrentDir = (Get-Location).Path
                        
                        # Get API container IP on the custom network
                        try {
                            $ApiInfo = docker inspect $env:API_CONTAINER | ConvertFrom-Json
                            $ApiIp = $ApiInfo[0].NetworkSettings.Networks[$env:PIPELINE_NETWORK].IPAddress
                            
                            if (-not $ApiIp) {
                                Write-Host "[ERROR] Could not get API container IP from network $env:PIPELINE_NETWORK"
                                exit 1
                            }
                        } catch {
                            Write-Host "[ERROR] Failed to inspect API container: $_"
                            exit 1
                        }
                        
                        Write-Host "[INFO] API container IP: $ApiIp"
                        
                        & docker run --rm `
                            --network $env:PIPELINE_NETWORK `
                            -v "$CurrentDir/postman:/postman" `
                            -v "$CurrentDir/monitoring-reports:/reports" `
                            postman/newman:alpine run /postman/products_api.postman_collection.json `
                            --env-var "baseUrl=http://$($ApiIp):$env:API_PORT" `
                            --env-var "apiMonitoringKey=$env:MONITORING_CREDENTIALS_USR" `
                            --reporters json,cli `
                            --reporter-json-export /reports/monitoring-report.json
                        
                        if ($LASTEXITCODE -ne 0) {
                            Write-Host "[ERROR] Newman tests failed with exit code $LASTEXITCODE"
                            exit $LASTEXITCODE
                        }
                    '''
                }
            }
        }

        stage('Validate Results') {
            steps {
                dir("${WORK_DIR}") {
                    script {
                        try {
                            def report = readJSON file: 'monitoring-reports/monitoring-report.json'
                            def failures = report.run.failures.size()
                            
                            if (failures > 0) {
                                echo "Monitoring detected ${failures} failure(s)"
                                unstable("${failures} tests failed")
                            } else {
                                echo "All tests passed"
                            }
                        } catch(e) {
                            echo "Could not parse report: ${e.message}"
                            unstable("Report parsing failed")
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            dir("${WORK_DIR}") {
                archiveArtifacts artifacts: 'monitoring-reports/**', allowEmptyArchive: true
            }
        }
        failure {
            echo "API Monitoring Failed"
        }
    }
}
