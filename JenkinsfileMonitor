pipeline {
    agent any

    options {
        timestamps()
        timeout(time: 10, unit: 'MINUTES')
    }

    triggers {
        cron('H/30 * * * *')
    }

    environment {
        POSTMAN_API_KEY = credentials('postman-api-key')
        POSTMAN_MONITOR_ID = credentials('postman-monitor-id')
        WORK_DIR = 'github-src'
        API_CONTAINER = 'ws-assignment-api-container'
        PIPELINE_NETWORK = 'ws-assignment-net'
        API_PORT = '8000'
        GIT_REPO_URL = 'https://github.com/gliparelli21/Web_Services_assignment.git'
        BRANCH = 'main'
    }

    stages {
        stage('Clone Repository') {
            steps {
                bat '''
                    if exist "%WORK_DIR%" rmdir /s /q "%WORK_DIR%"
                    git clone --depth 1 --branch "%BRANCH%" "%GIT_REPO_URL%" "%WORK_DIR%"
                '''
            }
        }

        stage('Check API Availability') {
            steps {
                dir("${WORK_DIR}") {
                    bat '''
                        setlocal enabledelayedexpansion
                        
                        docker inspect -f "{{.State.Running}}" %API_CONTAINER% >nul 2>&1
                        if !errorlevel! equ 0 (
                            echo [INFO] API container exists, checking health...
                            docker exec %API_CONTAINER% curl -fsS http://localhost:8000/docs >nul 2>&1
                            if !errorlevel! equ 0 (
                                echo [PASS] API container is healthy
                                exit /b 0
                            ) else (
                                echo [WARN] Container exists but API not responding, restarting...
                                docker restart %API_CONTAINER%
                                timeout /t 5 /nobreak >nul
                                exit /b 0
                            )
                        )
                        
                        echo [FAIL] API container not found - run main pipeline first to start API
                        exit /b 1
                    '''
                }
            }
        }

        stage('Run Postman Monitor') {
            steps {
                dir("${WORK_DIR}") {
                    bat '''
                        setlocal enabledelayedexpansion
                        if not exist monitoring-reports mkdir monitoring-reports
                        
                        for /f "delims=" %%A in ('cd') do set "CURRENT_DIR=%%A"
                        
                        docker run --rm ^
                            --add-host host.docker.internal:host-gateway ^
                            --network %PIPELINE_NETWORK% ^
                            -v "!CURRENT_DIR!/postman:/postman" ^
                            -v "!CURRENT_DIR!/monitoring-reports:/reports" ^
                            postman/newman:alpine run /postman/products_api.postman_collection.json ^
                            --env-var "baseUrl=http://host.docker.internal:%API_PORT%" ^
                            --reporters json,cli ^
                            --reporter-json-export /reports/monitoring-report.json
                    '''
                }
            }
        }

        stage('Push Results to Postman Dashboard') {
            steps {
                dir("${WORK_DIR}") {
                    powershell '''
                        $ReportPath = "monitoring-reports/monitoring-report.json"
                        
                        if (!(Test-Path $ReportPath)) {
                            Write-Host "[WARN] Report not found, skipping Postman push"
                            exit 0
                        }
                        
                        $Report = Get-Content $ReportPath -Raw | ConvertFrom-Json
                        $ApiKey = $env:POSTMAN_API_KEY
                        $MonitorId = $env:POSTMAN_MONITOR_ID
                        
                        if (-not $ApiKey -or -not $MonitorId) {
                            Write-Host "[WARN] Postman API key or Monitor ID not configured"
                            exit 0
                        }
                        
                        # Build run data for Postman
                        $RunData = @{
                            result = @{
                                stats = $Report.run.stats
                                failures = @($Report.run.failures)
                                executions = $Report.run.executions
                                timings = $Report.run.timings
                                environment = @{
                                    baseUrl = "http://host.docker.internal:8000"
                                }
                            }
                            status = if ($Report.run.failures.Count -eq 0) { "passed" } else { "failed" }
                        }
                        
                        # Post to Postman API
                        try {
                            $Headers = @{
                                "X-API-Key" = $ApiKey
                                "Content-Type" = "application/json"
                            }
                            
                            $Url = "https://api.getpostman.com/monitoring/monitors/$MonitorId/runs"
                            $Body = $RunData | ConvertTo-Json -Depth 10
                            
                            Write-Host "[INFO] Posting results to Postman Monitor: $MonitorId"
                            $Response = Invoke-WebRequest -Uri $Url -Method POST -Headers $Headers -Body $Body -ErrorAction Stop
                            
                            Write-Host "[PASS] Results successfully pushed to Postman"
                            Write-Host "[INFO] View at: https://app.postman.com/workspaces"
                        } catch {
                            Write-Host "[WARN] Could not push to Postman API: $_"
                            Write-Host "[INFO] Monitored data summary: Requests=$($Report.run.stats.requests.total), Passed=$($Report.run.stats.assertions.total - $Report.run.failures.Count), Failed=$($Report.run.failures.Count)"
                        }
                    '''
                }
            }
        }


    }

    post {
        always {
            dir("${WORK_DIR}") {
                archiveArtifacts artifacts: 'monitoring-reports/**', allowEmptyArchive: true
            }
        }
        failure {
            echo "API Monitoring Failed"
        }
    }
}
